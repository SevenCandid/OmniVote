[MASTER]
init-hook='import sys; sys.path.append("apps/api")'
extension-pkg-allow-list=pydantic

[TYPECHECK]
ignored-classes=alembic.op
generated-members=alembic.op.*

[MESSAGES CONTROL]
disable=
    missing-docstring,
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    line-too-long,
    invalid-name,
    logging-fstring-interpolation,
    broad-exception-caught,
    trailing-whitespace,
    singleton-comparison
