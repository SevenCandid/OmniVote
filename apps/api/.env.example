# OmniVote API Environment Configurations

# Application Configurations
PROJECT_NAME="OmniVote API"
ENV=development
DEBUG=True
API_V1_STR=/api/v1

# Security Configurations
# WARNING: Change this key in staging and production environments
SECRET_KEY=change_me_to_a_secure_random_hash_in_production_environments

# Database Configuration
# Placeholder for future PostgreSQL connection
DATABASE_URL=postgresql+asyncpg://postgres:securepassword@localhost:5432/omnivote

# Redis Cache and Celery Broker Configuration
# Placeholder for future Redis connection
REDIS_URL=redis://localhost:6379/0

# CORS Configurations
# Comma-separated list of origins, or "*"
BACKEND_CORS_ORIGINS=*
