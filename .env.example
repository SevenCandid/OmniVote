# ==============================================================================
# OmniVote Local Development Environment Configuration Template (.env.example)
# ==============================================================================
# Copy this file to a new file named '.env' before running docker compose up:
#   cp .env.example .env

# --- Global / Secrets Placeholder ---
# Generate a secure 32-character key for JWT signing
SECRET_KEY=change_me_to_a_secure_random_hash_in_production_environments

# --- Database Configurations ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=securepassword
POSTGRES_DB=omnivote
DATABASE_URL=postgresql+asyncpg://postgres:securepassword@omnivote-postgres:5432/omnivote

# --- Redis Cache & Celery Broker Configurations ---
REDIS_HOST=omnivote-redis
REDIS_PORT=6379
REDIS_URL=redis://omnivote-redis:6379/0

# --- Frontend Configurations (Vite) ---
# The URL pointing to the backend API accessible from the browser host
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/ws

# --- Asynchronous Worker configurations ---
CELERY_BROKER_URL=redis://omnivote-redis:6379/1
CELERY_RESULT_BACKEND=redis://omnivote-redis:6379/2

# --- MinIO Storage Configuration ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadminpassword
MINIO_ENDPOINT=omnivote-storage:9000
MINIO_BUCKET_NAME=omnivote-assets
